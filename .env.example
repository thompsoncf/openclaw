# Cerebro dos agentes (https://console.anthropic.com)
ANTHROPIC_API_KEY=coloque-sua-chave-aqui

# Modelo (opcional). Padrao: claude-sonnet-4-6
OPENCLAW_MODEL=claude-sonnet-4-6

# Banco de dados Postgres
DATABASE_URL=postgresql://openclaw:senha@localhost:5432/openclaw

# Token do bot do Telegram (crie com o @BotFather)
TELEGRAM_TOKEN=coloque-o-token-do-botfather-aqui
